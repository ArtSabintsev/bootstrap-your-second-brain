<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Daily multi-source ingest into the second-brain vault (X bookmarks, Goodreads,
  Substack, GitHub, podcasts, YouTube likes). Read-only against the external
  accounts.
  Before installing: edit the ProgramArguments path below to point at wherever
  you cloned this repo (default assumes ~/Developer/second-brain).
  Install:
    cp scripts/com.brain.ingest.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.brain.ingest.plist
  Remove:
    launchctl unload ~/Library/LaunchAgents/com.brain.ingest.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.brain.ingest</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>"$HOME/Developer/second-brain/scripts/ingest-daily.sh"</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>8</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>/tmp/brain.ingest.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/brain.ingest.err.log</string>
</dict>
</plist>

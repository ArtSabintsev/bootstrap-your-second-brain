# Per-user config (copy from config.example.json; may hold no secrets but stays local)
config.json

# Python tooling (vendored xtap CLI + venv)
.venv/
__pycache__/
*.egg-info/
*.pyc

# Machine-local pipeline state (run logs, skip logs)
.status/

# Generated intelligence indexes (rebuilt from notes; keep the folder, not the contents)
_indexes/*
!_indexes/.gitkeep

# Local operator log day files are fine to commit; ignore nothing under Log/

# Obsidian per-device state
.obsidian/
.DS_Store

# Local scratch / marketing decks that must not ship in the template
Drafts/**/*
!Drafts/.gitkeep
